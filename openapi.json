{"openapi": "3.1.0", "info": {"title": "Polaris Neuro Guard", "version": "1.0.0"}, "paths": {"/health": {"get": {"summary": "Health Check", "operationId": "health_check_health_get", "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {}}}}}}}, "/api/v1/status": {"get": {"summary": "Get API router status", "description": "Returns the initialization status of the simulation API router.", "operationId": "get_status_api_v1_status_get", "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/StatusResponse"}}}}}}}, "/api/v1/simulation/register": {"post": {"summary": "Register new user profile and initialize simulation", "description": "Registers a user profile containing role, scale, industry, anchor goals, and risk tolerance.\nInitializes simulation coordinates at (0,0) with destination targets set.", "operationId": "register_simulation_api_v1_simulation_register_post", "requestBody": {"content": {"application/json": {"schema": {"$ref": "#/components/schemas/UserProfile"}}}, "required": true}, "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/RegisterSimulationResponse"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/simulation/evaluate-decision": {"post": {"summary": "Evaluate decision step telemetry, deadlocks, and path collisions", "description": "Executes a single simulation step based on the user's steering intent, active constraints, and storms.\n\nRuns real-time logical deadlock checking and capsule path collision projection. Returns full telemetry\nand registers human-in-the-loop (HITL) alerts if failure thresholds are violated.", "operationId": "evaluate_decision_api_v1_simulation_evaluate_decision_post", "requestBody": {"content": {"application/json": {"schema": {"$ref": "#/components/schemas/EvaluateDecisionRequest"}}}, "required": true}, "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/EvaluateDecisionResponse"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/simulation/{simulation_id}/history": {"get": {"summary": "Fetch chronological history of a simulation session", "description": "Fetches the complete historical array of telemetry, drift, constraints, and events for a simulation session.", "operationId": "get_simulation_history_api_v1_simulation__simulation_id__history_get", "parameters": [{"name": "simulation_id", "in": "path", "required": true, "schema": {"type": "string", "title": "Simulation Id"}}], "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SimulationHistoryResponse"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/simulation/{simulation_id}/inject-storm": {"post": {"summary": "Dynamically inject or modify a custom environmental storm", "description": "Injects a new custom environmental storm or updates an existing one for the session.\nSubsequent evaluation turns will process this storm vector if included in active_storms.", "operationId": "inject_storm_api_v1_simulation__simulation_id__inject_storm_post", "parameters": [{"name": "simulation_id", "in": "path", "required": true, "schema": {"type": "string", "title": "Simulation Id"}}], "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/InjectStormRequest"}}}}, "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/InjectStormResponse"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}}, "components": {"schemas": {"AnchorGoal": {"properties": {"title": {"type": "string", "title": "Title", "description": "The title of the strategic goal", "examples": ["Migrate Core Infrastructure"]}, "target_timeline_months": {"type": "integer", "exclusiveMinimum": 0.0, "title": "Target Timeline Months", "description": "Target timeline in months", "examples": [18]}, "budget_limit_usd": {"type": "number", "exclusiveMinimum": 0.0, "title": "Budget Limit Usd", "description": "Strategic budget limit in USD", "examples": [5000000.0]}, "reliability_target_sla": {"type": "number", "maximum": 100.0, "minimum": 0.0, "title": "Reliability Target Sla", "description": "Target reliability SLA (0.0 to 100.0)", "examples": [99.95]}}, "type": "object", "required": ["title", "target_timeline_months", "budget_limit_usd", "reliability_target_sla"], "title": "AnchorGoal"}, "EvaluateDecisionRequest": {"properties": {"simulation_id": {"type": "string", "title": "Simulation Id", "description": "The unique simulation session ID returned on registration", "examples": ["64afce2a-7f67-4307-9b63-4a5491966940"]}, "intent_vector": {"$ref": "#/components/schemas/Vector2DModel", "description": "The User's intentional velocity and direction"}, "declared_constraints": {"items": {"type": "string"}, "type": "array", "title": "Declared Constraints", "description": "Active constraints declared by the user", "examples": [["RIGID_TIMELINE", "FREEZE_HEADCOUNT"]]}, "active_storms": {"items": {"type": "string"}, "type": "array", "title": "Active Storms", "description": "Names of active environmental storms (e.g. 'Category 4 Cyclone')", "examples": [["Category 4 Cyclone"]]}, "custom_icebergs": {"anyOf": [{"items": {"$ref": "#/components/schemas/IcebergModel"}, "type": "array"}, {"type": "null"}], "title": "Custom Icebergs", "description": "Optional custom icebergs to inject"}, "custom_opposing_pairs": {"anyOf": [{"items": {"prefixItems": [{"type": "string"}, {"type": "string"}], "type": "array", "maxItems": 2, "minItems": 2}, "type": "array"}, {"type": "null"}], "title": "Custom Opposing Pairs", "description": "Optional custom opposing constraint pairs to evaluate"}}, "type": "object", "required": ["simulation_id", "intent_vector"], "title": "EvaluateDecisionRequest"}, "EvaluateDecisionResponse": {"properties": {"simulation_id": {"type": "string", "title": "Simulation Id", "description": "The simulation session ID"}, "telemetry": {"$ref": "#/components/schemas/TelemetryModel", "description": "Telemetry details of this step"}, "drift_warning": {"type": "boolean", "title": "Drift Warning", "description": "Drift flag warning (True if angular drift > 15\u00b0)"}, "deadlocks": {"items": {"prefixItems": [{"type": "string"}, {"type": "string"}], "type": "array", "maxItems": 2, "minItems": 2}, "type": "array", "title": "Deadlocks", "description": "List of active logical deadlock pairs"}, "collision_threats": {"items": {"type": "string"}, "type": "array", "title": "Collision Threats", "description": "List of threatened iceberg names"}, "hitl_interception_data": {"anyOf": [{"$ref": "#/components/schemas/HITLInterceptionData"}, {"type": "null"}], "description": "Interception block if threats or deadlocks are present"}, "status": {"type": "string", "title": "Status", "description": "Simulation run status (RUNNING, PAUSED_BY_GUARDRAIL)", "default": "RUNNING"}, "active_constraints": {"items": {"type": "string"}, "type": "array", "title": "Active Constraints", "description": "Active constraint flags (e.g. ENGINE_STALL, BUDGET_OVERRUN)"}}, "type": "object", "required": ["simulation_id", "telemetry", "drift_warning", "deadlocks", "collision_threats"], "title": "EvaluateDecisionResponse"}, "HITLInterceptionData": {"properties": {"requires_intervention": {"type": "boolean", "title": "Requires Intervention", "description": "Flags if Human-in-the-Loop intervention is required"}, "reason": {"type": "string", "title": "Reason", "description": "Reason detail for the required intervention"}, "telemetry_snapshot": {"additionalProperties": true, "type": "object", "title": "Telemetry Snapshot", "description": "Diagnostic snapshot of the failure state"}}, "type": "object", "required": ["requires_intervention", "reason", "telemetry_snapshot"], "title": "HITLInterceptionData"}, "HTTPValidationError": {"properties": {"detail": {"items": {"$ref": "#/components/schemas/ValidationError"}, "type": "array", "title": "Detail"}}, "type": "object", "title": "HTTPValidationError"}, "HistoryStepLog": {"properties": {"turn_number": {"type": "integer", "title": "Turn Number", "description": "1-indexed turn number", "examples": [1]}, "telemetry_snapshot": {"$ref": "#/components/schemas/TelemetryModel", "description": "Telemetry snapshot at the end of the turn"}, "active_storms": {"items": {"type": "string"}, "type": "array", "title": "Active Storms", "description": "List of active storms in this turn", "examples": [["Category 4 Cyclone"]]}, "applied_decision": {"additionalProperties": true, "type": "object", "title": "Applied Decision", "description": "User decision applied in this turn"}, "fracture_events": {"additionalProperties": true, "type": "object", "title": "Fracture Events", "description": "Active constraints, deadlocks, and collisions"}}, "type": "object", "required": ["turn_number", "telemetry_snapshot", "active_storms", "applied_decision", "fracture_events"], "title": "HistoryStepLog"}, "IcebergModel": {"properties": {"name": {"type": "string", "title": "Name", "description": "The name of the iceberg constraint", "examples": ["Custom Budget Freeze"]}, "x": {"type": "number", "title": "X", "description": "X coordinate of the iceberg center", "examples": [-100.0]}, "y": {"type": "number", "title": "Y", "description": "Y coordinate of the iceberg center", "examples": [400.0]}, "radius": {"type": "number", "title": "Radius", "description": "The safety boundary radius around the iceberg", "default": 100.0, "examples": [100.0]}}, "type": "object", "required": ["name", "x", "y"], "title": "IcebergModel"}, "InjectStormRequest": {"properties": {"storm_type": {"$ref": "#/components/schemas/StormType", "description": "The type classification of the storm"}, "name": {"type": "string", "title": "Name", "description": "The unique identifier name of the storm", "examples": ["Custom Solar Flare"]}, "magnitude": {"type": "number", "minimum": 0.0, "title": "Magnitude", "description": "The magnitude/force speed of the storm vector", "examples": [8.0]}, "heading_degrees": {"type": "number", "maximum": 360.0, "minimum": 0.0, "title": "Heading Degrees", "description": "The heading direction of the storm vector in degrees (0 to 360)", "examples": [180.0]}}, "type": "object", "required": ["storm_type", "name", "magnitude", "heading_degrees"], "title": "InjectStormRequest"}, "InjectStormResponse": {"properties": {"status": {"type": "string", "title": "Status", "description": "Status of the injection request", "examples": ["success"]}, "injected_storm": {"$ref": "#/components/schemas/InjectStormRequest", "description": "The injected storm details"}, "active_custom_storms": {"items": {"type": "string"}, "type": "array", "title": "Active Custom Storms", "description": "List of all currently registered custom storm names"}}, "type": "object", "required": ["status", "injected_storm", "active_custom_storms"], "title": "InjectStormResponse"}, "RegisterSimulationResponse": {"properties": {"simulation_id": {"type": "string", "title": "Simulation Id", "description": "The generated simulation session ID"}, "quantum_mountain_coordinates": {"additionalProperties": {"type": "number"}, "type": "object", "title": "Quantum Mountain Coordinates", "description": "Locked-in Quantum Mountain coordinates"}, "user_profile": {"$ref": "#/components/schemas/UserProfile", "description": "The registered user profile details"}}, "type": "object", "required": ["simulation_id", "quantum_mountain_coordinates", "user_profile"], "title": "RegisterSimulationResponse"}, "RiskTolerance": {"type": "string", "enum": ["Conservative", "Balanced", "Aggressive"], "title": "RiskTolerance"}, "SimulationHistoryResponse": {"properties": {"simulation_id": {"type": "string", "title": "Simulation Id", "description": "The simulation session ID"}, "total_turns_executed": {"type": "integer", "title": "Total Turns Executed", "description": "Total turns executed in this simulation"}, "history": {"items": {"$ref": "#/components/schemas/HistoryStepLog"}, "type": "array", "title": "History", "description": "List of step logs"}}, "type": "object", "required": ["simulation_id", "total_turns_executed", "history"], "title": "SimulationHistoryResponse"}, "StatusResponse": {"properties": {"status": {"type": "string", "title": "Status", "description": "API router status state", "examples": ["ready"]}}, "type": "object", "required": ["status"], "title": "StatusResponse"}, "StormType": {"type": "string", "enum": ["Geopolitical", "Meteorological", "Economic"], "title": "StormType"}, "TelemetryModel": {"properties": {"current_position": {"additionalProperties": {"type": "number"}, "type": "object", "title": "Current Position", "description": "New position coordinates (x, y)"}, "intent_vector": {"$ref": "#/components/schemas/Vector2DModel", "description": "User intentional vector"}, "resultant_vector": {"$ref": "#/components/schemas/Vector2DModel", "description": "Resultant velocity vector after storms and deadlocks"}, "actual_burn_rate": {"type": "number", "title": "Actual Burn Rate", "description": "Burn-rate cost for this turn"}, "angular_drift_delta": {"type": "number", "title": "Angular Drift Delta", "description": "Angular difference between intent and reality in degrees"}}, "type": "object", "required": ["current_position", "intent_vector", "resultant_vector", "actual_burn_rate", "angular_drift_delta"], "title": "TelemetryModel"}, "UserProfile": {"properties": {"user_id": {"type": "string", "title": "User Id", "description": "The unique ID of the user", "examples": ["user_123"]}, "role": {"type": "string", "title": "Role", "description": "The role of the user", "examples": ["Chief Technology Officer"]}, "company_scale": {"type": "string", "title": "Company Scale", "description": "The scale of the company", "examples": ["Enterprise"]}, "industry": {"type": "string", "title": "Industry", "description": "The industry of the company", "examples": ["Maritime Logistics"]}, "anchor_goal": {"$ref": "#/components/schemas/AnchorGoal", "description": "The registered anchor goal"}, "risk_tolerance": {"$ref": "#/components/schemas/RiskTolerance", "description": "Risk tolerance setting", "examples": ["Balanced"]}}, "type": "object", "required": ["user_id", "role", "company_scale", "industry", "anchor_goal", "risk_tolerance"], "title": "UserProfile"}, "ValidationError": {"properties": {"loc": {"items": {"anyOf": [{"type": "string"}, {"type": "integer"}]}, "type": "array", "title": "Location"}, "msg": {"type": "string", "title": "Message"}, "type": {"type": "string", "title": "Error Type"}, "input": {"title": "Input"}, "ctx": {"type": "object", "title": "Context"}}, "type": "object", "required": ["loc", "msg", "type"], "title": "ValidationError"}, "Vector2DModel": {"properties": {"magnitude": {"type": "number", "title": "Magnitude", "description": "Speed or magnitude of the vector", "examples": [10.0]}, "heading_degrees": {"type": "number", "title": "Heading Degrees", "description": "Direction in degrees from positive Y-axis (0-360\u00b0)", "examples": [0.0]}}, "type": "object", "required": ["magnitude", "heading_degrees"], "title": "Vector2DModel"}}}}
