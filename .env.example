# Project Configuration
PROJECT_NAME=Polaris Neuro Guard
VERSION=1.0.0
API_V1_STR=/api/v1

# Simulation Mechanics Defaults
BASE_BURN_RATE=100.0

# Network Settings
PORT=8000

# Gemini ADK Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
OFFLINE_MODE=false
MOCK_MODE=false

# Timeouts & Retries
GEMINI_TIMEOUT=30.0
A2A_TIMEOUT=60.0
ADK_RETRY_ATTEMPTS=3
ADK_RETRY_INITIAL_DELAY=2.0
ADK_RETRY_MAX_DELAY=10.0
ADK_RETRY_BACKOFF_FACTOR=2.0
